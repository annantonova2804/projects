# Required for the AI chat assistant. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Which OpenRouter model to use for chat (defaults to a fast/cheap model).
# The project targets Cerebras inference on OpenRouter for low-latency tool calling.
OPENROUTER_MODEL=openrouter/openai/gpt-4o-mini

# Optional: Massive (Polygon.io-compatible) API key for real market data.
# Leave empty to use the built-in GBM price simulator.
MASSIVE_API_KEY=

# Set to true for deterministic mock LLM responses (no network calls, used in tests/CI).
LLM_MOCK=false

# Starting virtual cash balance for a new portfolio.
STARTING_CASH=10000

# SQLite path (lazy-initialized on first request).
DB_PATH=db/finally.sqlite3
